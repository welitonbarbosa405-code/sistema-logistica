<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate"/>
  <meta http-equiv="Pragma" content="no-cache"/>
  <meta http-equiv="Expires" content="0"/>
  <meta name="csrf-token" content="{{ csrf_token() }}"/>
  <title>{{ title or 'Kuhn Parts Brasil • Sistema de Logística' }}</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='img/logo_kuhn.png') }}">
  <link rel="shortcut icon" type="image/png" href="{{ url_for('static', filename='img/logo_kuhn.png') }}">
  <link rel="apple-touch-icon" href="{{ url_for('static', filename='img/logo_kuhn.png') }}">

  <!-- Tailwind CDN (dev). Em produção, gere CSS via build. -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'kuhn-red': '#ED1C24',
            'kuhn-red-dark': '#C41E3A',
            'kuhn-red-light': '#FF4757',
            'kuhn-red-ultra-light': '#FEF2F2',
            'kuhn-navy': '#2E3440',
            'kuhn-navy-dark': '#1A1F2E',
            'kuhn-gold': '#D0B580',
            'kuhn-gold-dark': '#B8A066',
            'kuhn-gold-light': '#E8D199',
            'kuhn-gold-ultra-light': '#FFFBF0',
            'kuhn-dark-gray': '#4A4A4A',
            'kuhn-gray': '#E8E8E8',
            'kuhn-white': '#FFFFFF',
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}?v=3.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/login-enhancements.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/footer-responsive.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/slideshow-fix.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/header-enhancements.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/slideshow-premium.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/text-alternatives.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/expedicoes.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/portaria.css') }}?v=1.0">
  
  <style>
    /* SIDEBAR STYLES */
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      width: 280px;
      height: 100vh;
      background: linear-gradient(135deg, #2E3440 0%, #1A1F2E 100%);
      box-shadow: 2px 0 20px rgba(0, 0, 0, 0.3);
      z-index: 1000;
      overflow-y: auto;
      overflow-x: hidden;
      transition: transform 0.3s ease;
    }

    .sidebar.collapsed {
      transform: translateX(-280px);
    }

    .sidebar-header {
      padding: 20px;
      border-bottom: 2px solid rgba(237, 28, 36, 0.3);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .sidebar-logo {
      width: 50px;
      height: 50px;
      border-radius: 8px;
      background: rgba(237, 28, 36, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .sidebar-logo img {
      width: 35px;
      height: 35px;
    }

    .sidebar-brand {
      flex: 1;
    }

    .sidebar-brand-title {
      font-size: 11px;
      color: #999;
      font-weight: 600;
      letter-spacing: 1px;
    }

    .sidebar-brand-name {
      font-size: 14px;
      color: #ED1C24;
      font-weight: 700;
    }

    .sidebar-menu {
      padding: 20px 0;
      list-style: none;
    }

    .sidebar-menu-item {
      margin: 0;
      padding: 0;
    }

    .sidebar-menu-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      color: #b0b8c1;
      text-decoration: none;
      transition: all 0.3s ease;
      border-left: 3px solid transparent;
      font-weight: 500;
      font-size: 14px;
    }

    .sidebar-menu-link:hover {
      background: rgba(237, 28, 36, 0.1);
      color: #ED1C24;
      border-left-color: #ED1C24;
    }

    .sidebar-menu-link.active {
      background: rgba(237, 28, 36, 0.15);
      color: #ED1C24;
      border-left-color: #ED1C24;
    }

    .sidebar-menu-icon {
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .sidebar-menu-text {
      flex: 1;
    }

    .sidebar-divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      margin: 15px 0;
    }

    .sidebar-footer {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 15px 20px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(0, 0, 0, 0.3);
    }

    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }

    .sidebar-user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #ED1C24;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: bold;
      font-size: 16px;
    }

    .sidebar-user-info {
      flex: 1;
      min-width: 0;
    }

    .sidebar-user-name {
      font-size: 13px;
      color: white;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .sidebar-user-role {
      font-size: 11px;
      color: #999;
    }

    .sidebar-logout {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px;
      background: rgba(237, 28, 36, 0.9);
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-weight: 600;
      font-size: 13px;
    }

    .sidebar-logout:hover {
      background: #ED1C24;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(237, 28, 36, 0.4);
    }

    /* MAIN CONTENT */
    .main-wrapper {
      margin-left: 280px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      transition: margin-left 0.3s ease;
    }

    .main-wrapper.sidebar-collapsed {
      margin-left: 0;
    }

    .topbar {
      background: white;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .toggle-sidebar-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 20px;
      color: #2E3440;
      padding: 8px;
      border-radius: 6px;
      transition: all 0.3s ease;
    }

    .toggle-sidebar-btn:hover {
      background: #f0f0f0;
    }

    .topbar-title {
      font-size: 16px;
      font-weight: 600;
      color: #2E3440;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    main {
      flex: 1;
      padding: 24px;
      background: linear-gradient(135deg, #E8E8E8 0%, #F5F5F5 100%);
    }

    footer {
      background: white;
      border-top: 1px solid #e0e0e0;
      padding: 16px 24px;
      margin-left: 280px;
      transition: margin-left 0.3s ease;
    }

    footer.sidebar-collapsed {
      margin-left: 0;
    }

    /* RESPONSIVO MOBILE */
    @media (max-width: 1024px) {
      .sidebar {
        width: 240px;
      }

      .main-wrapper {
        margin-left: 0;
      }

      .sidebar.mobile-open {
        transform: translateX(0);
      }

      .sidebar.mobile-closed {
        transform: translateX(-240px);
      }

      footer {
        margin-left: 0;
      }
    }

    @media (max-width: 640px) {
      .sidebar {
        width: 200px;
      }

      .sidebar-brand-name {
        font-size: 12px;
      }

      .sidebar-menu-link {
        padding: 10px 15px;
        font-size: 13px;
      }

      .topbar {
        padding: 12px 16px;
      }

      main {
        padding: 16px;
      }
    }
  </style>

  {% block extra_css %}{% endblock %}
</head>
<body class="bg-kuhn-gray" style="background: linear-gradient(135deg, #E8E8E8 0%, #F5F5F5 100%); min-height: 100vh;">
  
  {% if disable_nav is not defined or not disable_nav %}
    <!-- SIDEBAR NAVIGATION -->
    <nav class="sidebar" id="sidebar">
      <!-- Logo e Brand -->
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <img src="{{ url_for('static', filename='img/logo_kuhn.png') }}" alt="Kuhn">
        </div>
        <div class="sidebar-brand">
          <div class="sidebar-brand-title">Sistema de</div>
          <div class="sidebar-brand-name">Logística</div>
        </div>
      </div>

      <!-- Menu Principal -->
      <ul class="sidebar-menu">
        <li class="sidebar-menu-item">
          <a href="{{ url_for('cidades.index') }}" class="sidebar-menu-link{% if request.endpoint == 'cidades.index' %} active{% endif %}">
            <span class="sidebar-menu-icon">🏙️</span>
            <span class="sidebar-menu-text">Cidades Atendidas</span>
          </a>
        </li>
        <li class="sidebar-menu-item">
          <a href="{{ url_for('rastreamento.index') }}" class="sidebar-menu-link{% if request.endpoint == 'rastreamento.index' %} active{% endif %}">
            <span class="sidebar-menu-icon">📍</span>
            <span class="sidebar-menu-text">Rastreamento</span>
          </a>
        </li>
        <li class="sidebar-menu-item">
          <a href="{{ url_for('expedicoes.index') }}" class="sidebar-menu-link{% if request.endpoint == 'expedicoes.index' %} active{% endif %}">
            <span class="sidebar-menu-icon">📦</span>
            <span class="sidebar-menu-text">Expedições</span>
          </a>
        </li>
        <li class="sidebar-menu-item">
          <a href="{{ url_for('consumiveis.index') }}" class="sidebar-menu-link{% if request.endpoint == 'consumiveis.index' %} active{% endif %}">
            <span class="sidebar-menu-icon">⚙️</span>
            <span class="sidebar-menu-text">Consumíveis</span>
          </a>
        </li>

        <div class="sidebar-divider"></div>

        <li class="sidebar-menu-item">
          <a href="{{ url_for('lancamentos.lista_lancamentos') }}" class="sidebar-menu-link{% if request.endpoint.startswith('lancamentos.') and not request.endpoint.startswith('lancamentos_cte.') %} active{% endif %}">
            <span class="sidebar-menu-icon">📄</span>
            <span class="sidebar-menu-text">Lançamentos Fiscais</span>
          </a>
        </li>
        <li class="sidebar-menu-item">
          <a href="{{ url_for('lancamentos_cte.lista_lancamentos') }}" class="sidebar-menu-link{% if request.endpoint.startswith('lancamentos_cte.') %} active{% endif %}">
            <span class="sidebar-menu-icon">📋</span>
            <span class="sidebar-menu-text">Lançamentos CTe</span>
          </a>
        </li>

        {% if current_user.is_authenticated and current_user.role == 'admin' %}
          <div class="sidebar-divider"></div>
          <li class="sidebar-menu-item">
            <a href="{{ url_for('auth.register') }}" class="sidebar-menu-link{% if request.endpoint == 'auth.register' %} active{% endif %}">
              <span class="sidebar-menu-icon">👥</span>
              <span class="sidebar-menu-text">Usuários</span>
            </a>
          </li>
        {% endif %}
      </ul>

      <!-- Footer do Sidebar -->
      <div class="sidebar-footer">
        {% if current_user.is_authenticated %}
          <div class="sidebar-user">
            <div class="sidebar-user-avatar">
              {{ current_user.email[0].upper() }}
            </div>
            <div class="sidebar-user-info">
              <div class="sidebar-user-name">{{ current_user.email.split('@')[0]|capitalize }}</div>
              <div class="sidebar-user-role">
                {% if current_user.role == 'admin' %}ADMIN{% else %}Usuário{% endif %}
              </div>
            </div>
          </div>
          <a href="{{ url_for('auth.logout') }}" class="sidebar-logout">
            <span>🚪</span>
            <span>Sair</span>
          </a>
        {% else %}
          <a href="{{ url_for('auth.login') }}" class="sidebar-logout">
            <span>🔐</span>
            <span>Entrar</span>
          </a>
        {% endif %}
      </div>
    </nav>

    <!-- TOP BAR -->
    <div class="main-wrapper" id="mainWrapper">
      <header class="topbar">
        <div class="topbar-left">
          <button class="toggle-sidebar-btn" id="toggleSidebarBtn" title="Toggle sidebar">
            ☰
          </button>          <span class="topbar-title">
            {% if request.endpoint == 'cidades.index' %}Cidades Atendidas
            {% elif request.endpoint == 'rastreamento.index' %}Rastreamento
            {% elif request.endpoint == 'expedicoes.index' %}Expedições
            {% elif request.endpoint == 'consumiveis.index' %}Consumíveis
            {% elif request.endpoint.startswith('lancamentos.') %}Lançamentos Fiscais
            {% elif request.endpoint.startswith('lancamentos_cte.') %}Lançamentos CTe
            {% elif request.endpoint == 'auth.register' %}Gerenciar Usuários
            {% else %}Kuhn Parts Brasil
            {% endif %}
          </span>
        </div>
        <div class="topbar-right">
                  <!-- Espaço para adicionar elementos adicionais -->
        </div>
      </header>

      <main class="flex-1">
        {% if suppress_flashed_messages is not defined or not suppress_flashed_messages %}
          {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
              <div class="mb-4 space-y-2">
                {% for category, message in messages %}
                  <div class="p-3 rounded {{ 'bg-red-50 border border-red-200 text-red-700' if category=='danger' else 'bg-white border border-gray-200 text-gray-700' }}">
                    {{ message }}
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          {% endwith %}
        {% endif %}

        {% block content %}{% endblock %}
      </main>
    </div>
  {% endif %}

  {% if disable_footer is not defined or not disable_footer %}
    <footer id="footer">
      <div class="flex items-center justify-between text-xs text-gray-600">
        <div>
          <strong>Kuhn Parts Brasil</strong> • Sistema de Logística
        </div>
        <div class="flex gap-4">
          <span>👤 {{ current_user.email if current_user.is_authenticated else 'Visitante' }}</span>
          <span>🕐 <span id="footerHora">--:--:--</span></span>
          <span id="footerYear">© 2025</span>
        </div>
      </div>
    </footer>

    <script src="{{ url_for('static', filename='js/datetime.js') }}"></script>
    <script src="{{ url_for('static', filename='js/loading-system.js') }}"></script>
    <script src="{{ url_for('static', filename='js/micro-interactions.js') }}"></script>
    <script src="{{ url_for('static', filename='js/login-system.js') }}"></script>
    <script src="{{ url_for('static', filename='js/responsive-system.js') }}"></script>
    <script src="{{ url_for('static', filename='js/toast-system.js') }}"></script>

    <script>
      // Toggle Sidebar
      const toggleBtn = document.getElementById('toggleSidebarBtn');
      const sidebar = document.getElementById('sidebar');
      const mainWrapper = document.getElementById('mainWrapper');
      const footer = document.getElementById('footer');
      let sidebarOpen = true;

      toggleBtn.addEventListener('click', () => {
        sidebarOpen = !sidebarOpen;
        
        if (window.innerWidth <= 1024) {
          // Mobile behavior
          sidebar.classList.toggle('mobile-closed');
          sidebar.classList.toggle('mobile-open');
        } else {
          // Desktop behavior
          sidebar.classList.toggle('collapsed');
          mainWrapper.classList.toggle('sidebar-collapsed');
          footer.classList.toggle('sidebar-collapsed');
        }
        
        localStorage.setItem('sidebarOpen', sidebarOpen);
      });

      // Restore sidebar state
      window.addEventListener('load', () => {
        const saved = localStorage.getItem('sidebarOpen');
        if (saved === 'false' && window.innerWidth > 1024) {
          sidebarOpen = false;
          sidebar.classList.add('collapsed');
          mainWrapper.classList.add('sidebar-collapsed');
          footer.classList.add('sidebar-collapsed');
        }
      });

      // Handle window resize
      window.addEventListener('resize', () => {
        if (window.innerWidth > 1024) {
          sidebar.classList.remove('mobile-closed', 'mobile-open');
        }
      });

      // Update time
      function atualizarHora() {
        const agora = new Date();
        const horaFormatada = agora.toLocaleTimeString('pt-BR', { 
          hour: '2-digit', 
          minute: '2-digit', 
          second: '2-digit' 
        });
        const footerHora = document.getElementById('footerHora');
        if (footerHora) footerHora.textContent = horaFormatada;
      }
      
      setInterval(atualizarHora, 1000);
      atualizarHora();
    </script>
  {% endif %}

</body>
</html>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="{{ url_for('static', filename='img/logo_kuhn.png') }}">
  <link rel="shortcut icon" type="image/png" href="{{ url_for('static', filename='img/logo_kuhn.png') }}">
  <link rel="apple-touch-icon" href="{{ url_for('static', filename='img/logo_kuhn.png') }}">

  <!-- Tailwind CDN (dev). Em produção, gere CSS via build. -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'kuhn-red': '#ED1C24',
            'kuhn-red-dark': '#C41E3A',
            'kuhn-red-light': '#FF4757',
            'kuhn-red-ultra-light': '#FEF2F2',
            'kuhn-navy': '#2E3440',
            'kuhn-navy-dark': '#1A1F2E',
            'kuhn-gold': '#D0B580',
            'kuhn-gold-dark': '#B8A066',
            'kuhn-gold-light': '#E8D199',
            'kuhn-gold-ultra-light': '#FFFBF0',
            'kuhn-dark-gray': '#4A4A4A',
            'kuhn-gray': '#E8E8E8',
            'kuhn-white': '#FFFFFF',
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}?v=3.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/login-enhancements.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/footer-responsive.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/slideshow-fix.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/header-enhancements.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/slideshow-premium.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/text-alternatives.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/expedicoes.css') }}?v=1.0">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/portaria.css') }}?v=1.0">
  {% block extra_css %}{% endblock %}
</head>
<body class="{{ body_class or '' }} bg-kuhn-gray min-h-screen flex flex-col" style="background: linear-gradient(135deg, #E8E8E8 0%, #F5F5F5 100%); min-height: 100vh; position: relative; overflow-x: hidden; overflow-y: auto; display: flex; flex-direction: column;">
  <!-- Efeito de parallax sutil no fundo -->
  <div class="parallax-background">
    <div class="parallax-layer" data-speed="0.5"></div>
    <div class="parallax-layer" data-speed="0.3"></div>
    <div class="parallax-layer" data-speed="0.1"></div>
  </div>
  {% if disable_nav is not defined or not disable_nav %}
    <header class="topbar">
      <div class="brand-group">
        <div class="brand-logos">
          <img src="{{ url_for('static', filename='img/logo_kuhn.png') }}" alt="Logo Kuhn" class="logo-kuhn">
        </div>
        <div class="brand-text">
          <span class="brand-title">SISTEMA DE LOGISTICA</span>
          <strong>Kuhn Parts Brasil</strong>
        </div>
      </div>
      <nav class="topnav" aria-label="Navegação principal">
        <a class="nav-pill{% if request.endpoint == 'cidades.index' %} nav-pill--active{% endif %}" href="{{ url_for('cidades.index') }}">Cidades Atendidas</a>
        <a class="nav-pill{% if request.endpoint == 'rastreamento.index' %} nav-pill--active{% endif %}" href="{{ url_for('rastreamento.index') }}">Rastreamento</a>
        <a class="nav-pill{% if request.endpoint == 'expedicoes.index' %} nav-pill--active{% endif %}" href="{{ url_for('expedicoes.index') }}">Expedições</a>        <a class="nav-pill{% if request.endpoint == 'consumiveis.index' %} nav-pill--active{% endif %}" href="{{ url_for('consumiveis.index') }}">Consumíveis</a>
        <a class="nav-pill{% if request.endpoint.startswith('lancamentos.') %} nav-pill--active{% endif %}" href="{{ url_for('lancamentos.lista_lancamentos') }}">Lançamentos Fiscais</a>
        <a class="nav-pill{% if request.endpoint.startswith('lancamentos_cte.') %} nav-pill--active{% endif %}" href="{{ url_for('lancamentos_cte.lista_lancamentos') }}">Lançamentos CTe</a>
        {% if current_user.is_authenticated %}
          {% if current_user.role == 'admin' %}
            <a class="nav-pill{% if request.endpoint == 'auth.register' %} nav-pill--active{% endif %}" href="{{ url_for('auth.register') }}">Usuários</a>
          {% endif %}
          <a class="nav-pill nav-pill--primary" href="{{ url_for('auth.logout') }}">Sair</a>
        {% else %}
          <a class="nav-pill nav-pill--primary" href="{{ url_for('auth.login') }}">Entrar</a>
        {% endif %}
      </nav>
    </header>
  {% endif %}

{% set _full_width = full_width if full_width is defined else True %}
{% if _full_width %}
<main class="flex-1 w-full">
{% else %}
<main class="max-w-7xl mx-auto px-6 py-6 flex-1 w-full" style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
{% endif %}
  {% if suppress_flashed_messages is not defined or not suppress_flashed_messages %}
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        <div class="mb-4 space-y-2">
          {% for category, message in messages %}
            <div class="p-3 rounded {{ 'bg-red-50 border border-red-200 text-red-700' if category=='danger' else 'bg-white border border-gray-200 text-gray-700' }}">
              {{ message }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    {% endwith %}
  {% endif %}

  {% block content %}{% endblock %}
</main>

{% if disable_footer is not defined or not disable_footer %}
  <!-- Rodapé Compacto - Uma única linha -->
  <!-- AJUSTE DE ALTURA DO RODAPÉ: 
       py-1 = altura mínima (muito compacto)
       py-2 = altura pequena (atual)
       py-3 = altura média (recomendado)
       py-4 = altura grande (mais espaçoso)
       py-5 = altura máxima (muito espaçoso)
       Para ajustar: mude apenas o número após "py-"
  -->
  <!-- Rodapé no estilo da tela de login -->
  <footer class="statusbar glass footer-portaria" aria-live="polite">
    <div class="status-left">
      <span class="status-user-icon" aria-hidden="true">👤</span>
      <span class="status-user-text">Usuário: <strong>{% if current_user.is_authenticated %}{{ current_user.email }}{% else %}Visitante{% endif %}</strong></span>
      {% if current_user.is_authenticated and current_user.role == 'admin' %}
        <span class="status-badge">ADMINISTRADOR</span>
      {% endif %}
    </div>
    <div class="status-center">
      <div class="status-date-box">
        <span>Dia: <strong id="footerDia">--</strong></span>
      </div>
      <span class="divider">•</span>
      <div class="status-date-box">
        <span>Data: <strong id="footerData">--/--/----</strong></span>
      </div>
      <span class="divider">•</span>
      <div class="status-date-box status-date-box--highlight">
        <span>Hora: <strong id="footerHora">--:--:--</strong></span>
      </div>
    </div>
    <div class="status-right">
      <span class="status-online">● Online</span>
      <span class="divider">•</span>
      <span class="status-company">Kuhn Parts Brasil</span>
      <span class="divider">•</span>
      <span id="footerYear">© 2025</span>
    </div>
  </footer>

  <!-- 🚀 SISTEMA DE DATA/HORA IMPRESSIONANTE -->
  <script src="{{ url_for('static', filename='js/datetime.js') }}"></script>

  <!-- 🚀 SISTEMA DE NOTIFICAÇÕES E EFEITOS IMPRESSIONANTES - DESABILITADO -->
  <!-- <script src="{{ url_for('static', filename='js/notifications.js') }}"></script> -->

  <!-- 🌙 SISTEMA DE MODO ESCURO/CLARO DINÂMICO - DESABILITADO -->
  <!-- <script src="{{ url_for('static', filename='js/theme.js') }}"></script> -->

  <!-- 📊 DASHBOARD DE MÉTRICAS EM TEMPO REAL - DESABILITADO -->
  <!-- <script src="{{ url_for('static', filename='js/analytics.js') }}"></script> -->

  <!-- 🚀 SISTEMAS IMPRESSIONANTES KUHN -->
  <!-- Sistema de notificações desabilitado conforme solicitado -->
  <!-- <script src="{{ url_for('static', filename='js/toast-notifications.js') }}"></script> -->
  <script src="{{ url_for('static', filename='js/loading-system.js') }}"></script>
  <script src="{{ url_for('static', filename='js/micro-interactions.js') }}"></script>
  <script src="{{ url_for('static', filename='js/login-system.js') }}"></script>
  <script src="{{ url_for('static', filename='js/responsive-system.js') }}"></script>
  <script src="{{ url_for('static', filename='js/toast-system.js') }}"></script>

  <!-- Script para relógio e data -->
  <script>
  function atualizarDataHora() {
    const agora = new Date();
    
    // Formatar data em português
    const opcoesData = { 
      weekday: 'long', 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric' 
    };
    const dataFormatada = agora.toLocaleDateString('pt-BR', opcoesData);
    
    // Formatar hora
    const horaFormatada = agora.toLocaleTimeString('pt-BR', { 
      hour: '2-digit', 
      minute: '2-digit', 
      second: '2-digit' 
    });
    
    // Elementos do cabeçalho removidos - informações agora estão no rodapé
    
    // Atualizar elementos do rodapé
    console.log('🔍 Procurando elementos do rodapé...');
    
    const footerDataEl = document.getElementById('footerData');
    const footerHoraEl = document.getElementById('footerHora');
    
    console.log('📅 Elemento Data:', footerDataEl);
    console.log('🕐 Elemento Hora:', footerHoraEl);
    
    if (footerDataEl) {
      // Data super compacta para o rodapé
      const dataCompacta = agora.toLocaleDateString('pt-BR', {
        day: '2-digit',
        month: '2-digit',
        year: '2-digit'
      });
      footerDataEl.textContent = dataCompacta;
      console.log('✅ Data atualizada:', dataCompacta);
    } else {
      console.error('❌ Elemento footerData NÃO ENCONTRADO!');
    }
    
    if (footerHoraEl) {
      footerHoraEl.textContent = horaFormatada;
      console.log('✅ Hora atualizada:', horaFormatada);
    } else {
      console.error('❌ Elemento footerHora NÃO ENCONTRADO!');
    }
    
  }
  
  // Efeitos visuais reduzidos para tema fixo
  function adicionarEfeitosVisuais() {
    // Tema claro fixo: sem animações adicionais no rodapé
  }
  
  // Função será chamada após o DOM estar pronto
  
  // Função simples para atualizar data e hora
  function atualizarSimples() {
    const agora = new Date();
    const data = agora.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: '2-digit' });
    const hora = agora.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    
    const dataEl = document.getElementById('footerData');
    const horaEl = document.getElementById('footerHora');
    
    if (dataEl) dataEl.textContent = data;
    if (horaEl) horaEl.textContent = hora;
    
    console.log('Data/Hora atualizadas:', data, hora);
  }

  // Limpar todas as notificações existentes
  function limparTodasNotificacoes() {
    // Remover containers de notificações
    const containers = [
      'kuhn-toast-container',
      'kuhn-notification-container',
      'notification-container'
    ];
    
    containers.forEach(containerId => {
      const container = document.getElementById(containerId);
      if (container) {
        container.remove();
      }
    });
    
    // Remover elementos com classes de notificação
    const notificationElements = document.querySelectorAll([
      '.kuhn-toast',
      '.kuhn-notification',
      '.notification',
      '.alert',
      '.toast'
    ].join(', '));
    
    notificationElements.forEach(element => {
      element.remove();
    });
    
    console.log('🧹 Todas as notificações foram removidas');
  }

  // Executar limpeza imediatamente
  limparTodasNotificacoes();

  // Executar quando a página carregar
  window.addEventListener('load', function() {
    console.log('🚀 Página carregada - Atualizando data/hora');
    atualizarSimples();
    setInterval(atualizarSimples, 1000);
    adicionarEfeitosVisuais();
    inicializarMenuMobile();
    
    // Limpar notificações novamente após carregamento
    limparTodasNotificacoes();
    
    // Limpar notificações periodicamente (a cada 5 segundos)
    setInterval(limparTodasNotificacoes, 5000);
    
    // Inicializar sistemas Kuhn (SEM notificações)
    inicializarSistemasKuhn();
  });

  // Função para inicializar sistemas Kuhn (SEM notificações)
    function inicializarSistemasKuhn() {
      console.log('🎉 Inicializando sistemas Kuhn (sem notificações)...');
      
      // Aplicar micro-interações automáticas
      if (window.kuhnMicro) {
        // Melhorar botões existentes
        document.querySelectorAll('button, .btn').forEach(btn => {
          kuhnMicro.enhanceButton(btn);
        });
        
        // Melhorar cards existentes
        document.querySelectorAll('.card, .result-item, .kpi-card').forEach(card => {
          kuhnMicro.enhanceCard(card);
        });
        
        // Melhorar inputs existentes
        document.querySelectorAll('input, select, textarea').forEach(input => {
          kuhnMicro.enhanceInput(input);
        });
        
        // Melhorar links existentes
        document.querySelectorAll('a, .nav-link').forEach(link => {
          kuhnMicro.enhanceLink(link);
        });
      }
      
      // Aplicar efeitos de entrada aos elementos
      document.querySelectorAll('.tracking-container, .result-card, .kpi-card').forEach((element, index) => {
        element.setAttribute('data-kuhn-effect', 'fade-in');
        element.setAttribute('data-kuhn-delay', index * 200);
      });
      
      console.log('✅ Sistemas Kuhn inicializados (sem notificações)!');
    }

  // Fallback imediato
  if (document.readyState === 'complete') {
    atualizarSimples();
    setInterval(atualizarSimples, 1000);
  }
  
  // Função para inicializar o menu mobile
  function inicializarMenuMobile() {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
        mobileMenu.classList.toggle('show');
        
        // Animação do ícone hambúrguer
        const icon = this.querySelector('svg');
        if (icon) {
          icon.classList.toggle('rotate-90');
        }
      });
      
      // Fechar menu ao clicar em um link
      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(link => {
        link.addEventListener('click', function() {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('show');
        });
      });
      
      // Fechar menu ao clicar fora
      document.addEventListener('click', function(e) {
        if (!mobileMenuBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('show');
        }
      });
    }
  }

  // Script inline para garantir execução
  console.log('🔥 Script carregado - testando elementos...');
  
  setTimeout(function() {
    console.log('⏰ Executando teste após 1 segundo...');
    const diaEl = document.getElementById('footerDia');
    const dataEl = document.getElementById('footerData');
    const horaEl = document.getElementById('footerHora');
    console.log('Elemento Dia:', diaEl);
    console.log('Elemento Data:', dataEl);
    console.log('Elemento Hora:', horaEl);
    
    if (diaEl && dataEl && horaEl) {
      const agora = new Date();
      const dia = agora.toLocaleDateString('pt-BR', { weekday: 'long' }); // Ex: "terça-feira"
      const data = agora.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: '2-digit' });
      const hora = agora.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      
      diaEl.textContent = dia;
      dataEl.textContent = data;
      horaEl.textContent = hora;
      
      console.log('✅ Dia/Data/Hora definidos:', dia, data, hora);
      
      // Atualizar a cada segundo
      setInterval(function() {
        const agora = new Date();
        const dia = agora.toLocaleDateString('pt-BR', { weekday: 'long' });
        const data = agora.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: '2-digit' });
        const hora = agora.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        diaEl.textContent = dia;
        dataEl.textContent = data;
        horaEl.textContent = hora;
      }, 1000);
    } else {
      console.error('❌ Elementos não encontrados!');
    }
  }, 1000);
  </script>
{% endif %}
<script src="{{ url_for('static', filename='js/navigation-smooth.js') }}?v=1.0"></script>
{% block extra_js %}{% endblock %}
</body>
</html>